# Firebase
FIREBASE_ADMIN_PRIVATE_KEY=/absolute/path/to/firebase-service-account.json

# APNs
APNS_AUTH_KEY=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
TEAM_ID=YOUR_APPLE_TEAM_ID
ALGORITHM=ES256
APNS_KEY_ID=YOUR_APNS_KEY_ID
BUNDLE_ID=com.example.app
IOS_HTTP_URL=api.push.apple.com:443
IOS_HTTP_SANDBOX_URL=api.development.push.apple.com:443

# Optional APNs tuning
MAX_LIST_SIZE=1000

